# Horizon Digital Monorepo Environment Configuration
# Copy this file to .env and configure

# =============================================================================
# PROJECT SETTINGS
# =============================================================================
PROJECT_NAME=horizon-digital
COMPOSE_PROJECT_NAME=horizon-digital

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
# Options: development, uat, production
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=horizon_digital
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5455
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/horizon_digital

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# =============================================================================
# CELERY CONFIGURATION
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=http://localhost:8080/
VITE_APP_NAME=Horizon Digital
NODE_ENV=development

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# SERVICE PORTS
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# =============================================================================
# DJANGO SPECIFIC SETTINGS
# =============================================================================
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# SECURITY SETTINGS (Production)
# =============================================================================
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# =============================================================================
# FILE STORAGE (Optional)
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# USE_S3=False

# =============================================================================
# MONITORING & ANALYTICS (Optional)
# =============================================================================
# SENTRY_DSN=
# GOOGLE_ANALYTICS_ID=

# =============================================================================
# BACKUP CONFIGURATION (Optional)
# =============================================================================
# BACKUP_S3_BUCKET=
# BACKUP_RETENTION_DAYS=30

# =============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATIONS
# =============================================================================

# DEVELOPMENT ENVIRONMENT SETTINGS
# Uncomment and use these for development
# ENVIRONMENT=development
# DEBUG=True
# POSTGRES_DB=horizon_digital_dev
# POSTGRES_PORT=5455
# REDIS_PORT=6380
# VITE_API_BASE_URL=http://localhost:8080/
# VITE_APP_NAME=Horizon Digital (Dev)
# NGINX_HTTP_PORT=8080
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
# CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# LOG_LEVEL=DEBUG
# SECURE_SSL_REDIRECT=False

# UAT ENVIRONMENT SETTINGS
# Uncomment and use these for UAT
# ENVIRONMENT=uat
# DEBUG=False
# SECRET_KEY=uat-secret-key-change-this
# POSTGRES_DB=horizon_digital_uat
# POSTGRES_PASSWORD=change-this-password
# POSTGRES_PORT=5434
# REDIS_PASSWORD=change-this-redis-password
# REDIS_PORT=6381
# VITE_API_BASE_URL=https://uat-api.horizondigital.com
# VITE_APP_NAME=Horizon Digital (UAT)
# NGINX_HTTP_PORT=8081
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# ALLOWED_HOSTS=uat.horizondigital.com,localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=https://uat.horizondigital.com,http://localhost:8081
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST_USER=your-email@domain.com
# EMAIL_HOST_PASSWORD=your-app-password
# LOG_LEVEL=INFO
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# PRODUCTION ENVIRONMENT SETTINGS
# Uncomment and use these for production
# ENVIRONMENT=production
# DEBUG=False
# SECRET_KEY=production-secret-key-generate-strong-key
# POSTGRES_DB=horizon_digital_prod
# POSTGRES_PASSWORD=super-secure-production-password
# REDIS_PASSWORD=super-secure-redis-password
# VITE_API_BASE_URL=https://api.horizondigital.com
# VITE_APP_NAME=Horizon Digital
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# ALLOWED_HOSTS=horizondigital.com,www.horizondigital.com,api.horizondigital.com
# CORS_ALLOWED_ORIGINS=https://horizondigital.com,https://www.horizondigital.com
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST_USER=noreply@horizondigital.com
# EMAIL_HOST_PASSWORD=your-production-email-password
# LOG_LEVEL=WARNING
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=horizon-digital-prod-storage
# USE_S3=True
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
