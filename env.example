# Monorepo Environment Configuration
PROJECT_NAME=monorepo-starter
COMPOSE_PROJECT_NAME=monorepo-starter
ENVIRONMENT=development

# Database
POSTGRES_DB=monorepo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Django Backend
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
BACKEND_PORT=8000
BACKEND_CONTAINER_NAME=${PROJECT_NAME}-backend
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:${BACKEND_PORT}
FRONTEND_PORT=3000
FRONTEND_CONTAINER_NAME=${PROJECT_NAME}-frontend
NODE_ENV=development

# Services
REDIS_PORT=6379
POSTGRES_PORT=5432
DB_CONTAINER_NAME=${PROJECT_NAME}-db
REDIS_CONTAINER_NAME=${PROJECT_NAME}-redis

# Networks
NETWORK_NAME=${PROJECT_NAME}-network